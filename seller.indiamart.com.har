            "text": "{\"res_code\":\"200\",\"results\":[{\"isEcomFlag\":\"0\",\"title\":\"17inch Kids Printed Polyester School Bag\",\"moq\":\"100\",\"displayid\":\"2849082372973\",\"datatype\":\"product\",\"ecom_item_landing_url\":\"\",\"ecom_cart_url\":\"\",\"ecom_store_master_name\":\"\",\"datarefid\":\"225422730\",\"isq\":[\"Gender==Unisex\",\"Type Of Bagpack==Kids Shoulder backpack\",\"Color==Brown(Base)\",\"Size/Dimension==12*17inch\",\"Material==Polyester\",\"Pattern==Printed\",\"Usage/Application==School\"],\"photo\":[\"http://5.imimg.com/data5/SELLER/Default/2022/12/BO/UC/NY/56238099/kids-printed-polyester-school-bags-125x125.jpeg\",\"http://5.imimg.com/data5/SELLER/Default/2022/12/BO/UC/NY/56238099/kids-printed-polyester-school-bags-250x250.jpeg\",\"http://5.imimg.com/data5/SELLER/Default/2022/12/BO/UC/NY/56238099/kids-printed-polyester-school-bags-500x500.jpeg\",\"\"],\"isphoto\":true,\"glusrid\":\"56238099\",\"companyname\":\"Regent Bags\",\"mcatid\":[\"96454\",\"442740\",\"8422\",\"PMCAT 8422\",\"96454A\",\"442740BA\",\"96454P\"],\"mcatname\":[\"Kids School Bag\",\"Polyester School Bag\"],\"CustTypeWt\":699,\"dispflagval\":\"1\",\"iildisplayflag\":1,\"lastactiondatet\":\"2026-04-28T18:52:04.000+00:00\",\"catalog_url\":\"https://www.regentbags.in/\",\"usrpcatname\":\"School Bag\",\"usrpcatflname\":\"school-bag.html\",\"prdstatus\":\"40\",\"itemprice2\":370,\"itemcurrency\":\"INR\",\"moq_type\":\"bag\",\"smalldescorg\":\"School bag WIth1 year manufacturing warranty&nbsp;<b>ersatile and Durable</b>: This large, waterproof bag in navy blue is perfect for students from 5th to 10th class, as well as for college and tuition, making it ideal for both boys and girls.<br /><br /><b>High Capacity</b>: With a carrying capacity of 45 liters, this bag provides ample space for all your school, college, or tuition essentials.<br /><br /><b>Multiple Compartments</b>: Featuring five compartments, this bag ensures organized storage for books, stationery, and other items.<br /><br /><b>Convenient Design</b>: Includes water bottle pockets on both sides for easy access and hydration on the go.<br /><br /><b>Durable and Waterproof</b>: Made with strong zippers and waterproof material, this bag is built to last and keep your belongings safe in any weather.\",\"hotnew\":\"\",\"itemcode\":\"\",\"prod_multiple_photos\":\"\",\"original_title\":\"17inch Kids Printed Polyester School Bag\"},{\"isEcomFlag\":\"0\",\"title\":\"Blue(Base) Unisex Kids Spider Man Printed Polyester School Bag\",\"moq\":\"100\",\"displayid\":\"2849082542248\",\"datatype\":\"product\",\"ecom_item_landing_url\":\"\",\"ecom_cart_url\":\"\",\"ecom_store_master_name\":\"\",\"datarefid\":\"225424423\",\"isq\":[\"Material==Polyester\",\"Color==Blue(Base)\",\"Usage/Application==School\",\"Pattern==Printed\",\"Type Of Bagpack==Kids Shoulder backpack\",\"Gender==Unisex\",\"Is It Waterproof==Waterproof\",\"Weight==500gm\"],\"photo\":[\"http://5.imimg.com/data5/SELLER/Default/2022/12/NZ/LS/BO/56238099/kids-spider-man-printed-polyester-school-bag-125x125.jpeg\",\"http://5.imimg.com/data5/SELLER/Default/2022/12/NZ/LS/BO/56238099/kids-spider-man-printed-polyester-school-bag-250x250.jpeg\",\"http://5.imimg.com/data5/SELLER/Default/2022/12/NZ/LS/BO/56238099/kids-spider-man-printed-polyester-school-bag-500x500.jpeg\",\"http://5.imimg.com/data5/SELLER/Default/2022/12/NZ/LS/BO/56238099/kids-spider-man-printed-polyester-school-bag-1000x1000.jpeg\"],\"isphoto\":true,\"glusrid\":\"56238099\",\"companyname\":\"Regent Bags\",\"mcatid\":[\"96454\",\"183056\",\"8422\",\"PMCAT 8422\",\"96454A\",\"183056BA\",\"96454P\"],\"mcatname\":[\"Kids School Bag\",\"Boys School Bag\"],\"CustTypeWt\":699,\"dispflagval\":\"1\",\"iildisplayflag\":1,\"lastactiondatet\":\"2026-04-28T18:52:04.000+00:00\",\"catalog_url\":\"https://www.regentbags.in/\",\"usrpcatname\":\"School Bag\",\"usrpcatflname\":\"school-bag.html\",\"prdstatus\":\"40\",\"itemprice2\":350,\"itemcurrency\":\"INR\",\"moq_type\":\"Bag\",\"smalldes