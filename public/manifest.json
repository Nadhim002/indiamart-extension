{
  "manifest_version": 3,
  "name": "Indiamart Lead Notifier",
  "version": "1.0.0",
  "description": "Monitor Indiamart buy-leads and receive alerts on your phone.",
  "key": "",
  "permissions": [
    "sidePanel",
    "scripting",
    "tabs",
    "activeTab",
    "alarms",
    "storage",
    "identity"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Indiamart Lead Notifier",
    "default_popup": "panel.html"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "host_permissions": [
    "<all_urls>",
    "https://*.firebaseio.com/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://exp.host/*",
    "https://accounts.google.com/*",
    "https://oauth2.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://*.firebaseio.com wss://*.firebaseio.com https://*.firebasedatabase.app wss://*.firebasedatabase.app https://*.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://exp.host https://accounts.google.com https://oauth2.googleapis.com;"
  }
}