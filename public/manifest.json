{
  "manifest_version": 3,
  "name": "Indiamart Side Panel",
  "version": "1.0.0",
  "description": "Chrome extension with a React side panel showing Hello World.",
  "permissions": [
    "sidePanel"
  ],
  "action": {
    "default_title": "Indiamart Side Panel",
    "default_popup": "panel.html"
  },
  "side_panel": {
    "default_path": "panel.html"
  }
}
